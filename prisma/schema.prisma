// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ─── Auth & Multi-Tenant Models ────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  sessions     Session[]
  projects     Project[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Project {
  id               String            @id @default(cuid())
  userId           String
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  name             String
  slug             String            @unique
  description      String            @default("")
  published        Boolean           @default(false)
  sidebarItems     SidebarItem[]
  headerComponents HeaderComponent[]
  chatMessages     ChatMessage[]
  appConfigs       AppConfig[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
}

// ─── Existing Models (with optional projectId for multi-tenant) ─

model SidebarItem {
  id        String   @id @default(cuid())
  label     String
  icon      String   @default("LayoutDashboard")
  slug      String
  order     Int      @default(0)
  parentId  String?
  parent    SidebarItem?  @relation("SidebarChildren", fields: [parentId], references: [id])
  children  SidebarItem[] @relation("SidebarChildren")
  page      Page?
  projectId String
  project   Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([slug, projectId])
}

model Page {
  id            String          @id @default(cuid())
  sidebarItemId String          @unique
  sidebarItem   SidebarItem     @relation(fields: [sidebarItemId], references: [id], onDelete: Cascade)
  components    PageComponent[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model PageComponent {
  id        String           @id @default(cuid())
  pageId    String
  page      Page             @relation(fields: [pageId], references: [id], onDelete: Cascade)
  parentId  String?
  parent    PageComponent?   @relation("ComponentChildren", fields: [parentId], references: [id], onDelete: Cascade)
  children  PageComponent[]  @relation("ComponentChildren")
  type      String
  config    String           @default("{}")
  order     Int              @default(0)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model AppConfig {
  id        String   @id @default(cuid())
  key       String
  value     String   @default("{}")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  @@unique([key, projectId])
}

model HeaderComponent {
  id        String   @id @default(cuid())
  type      String
  position  Int      @default(0)
  config    String   @default("{}")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ChatMessage {
  id        String   @id @default(cuid())
  role      String
  content   String
  actions   String?
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}
